{
  "name": "@twentytwohundred/web",
  "version": "0.0.0",
  "private": true,
  "description": "2200 web app. Talks to the runtime over the documented HTTP+WebSocket API.",
  "author": {
    "name": "TWENTYTWOHUNDRED LLC",
    "url": "https://2200.ai"
  },
  "license": "SEE LICENSE IN ../../LICENSE",
  "type": "module",
  "scripts": {
    "generate:tokens": "tsx scripts/generate-tokens.ts",
    "predev": "pnpm generate:tokens",
    "dev": "vite",
    "prebuild": "pnpm generate:tokens",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "pretest": "pnpm generate:tokens",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm generate:tokens && pnpm typecheck && pnpm lint && pnpm format:check && pnpm test && pnpm build"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.11",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-easy-crop": "^5.5.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.15.1",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.18.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.4.2",
    "tsx": "^4.22.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^5.4.10",
    "vitest": "^2.1.8"
  }
}
