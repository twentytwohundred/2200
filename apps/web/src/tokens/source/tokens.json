{
  "$schema": "https://2200.local/schemas/tokens-v1.1.json",
  "version": "1.1.0",
  "description": "2200 design tokens v1.1 ... single accent (green-for-alive), unprefixed semantic tokens, --ds-* system primitives, density + radius preset modifiers.",
  "naming": {
    "system": "--ds-<category>-<role>",
    "semantic": "--<role>[-<variant>]",
    "agent": "--agent-<n>",
    "rule": "System tokens use --ds- prefix. Semantic surface tokens (bg, text, line, accent, danger, warn, info) are unprefixed for ergonomic component CSS. Agent hues use --agent-1..6, hashed by name."
  },
  "type": {
    "family": {
      "sans": "'Switzer', ui-sans-serif, system-ui, -apple-system, 'Segoe UI', sans-serif",
      "mono": "'JetBrains Mono', ui-monospace, 'SF Mono', Menlo, Consolas, monospace"
    },
    "scale": {
      "2xs": "11px",
      "xs": "12px",
      "sm": "13px",
      "md": "15px",
      "lg": "17px",
      "xl": "22px",
      "2xl": "30px",
      "3xl": "44px"
    },
    "lh": {
      "tight": 1.18,
      "snug": 1.35,
      "prose": 1.55
    }
  },
  "space": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "8": "32px",
    "10": "40px",
    "12": "48px",
    "16": "64px",
    "20": "80px"
  },
  "radius": {
    "1": "4px",
    "2": "6px",
    "3": "10px",
    "4": "14px",
    "pill": "999px"
  },
  "radiusPresets": {
    "sharp": {
      "1": "0px",
      "2": "2px",
      "3": "4px",
      "4": "6px"
    },
    "soft": {
      "1": "6px",
      "2": "10px",
      "3": "14px",
      "4": "18px"
    }
  },
  "motion": {
    "ease": "cubic-bezier(.2,.7,.2,1)",
    "duration": {
      "fast": "120ms",
      "normal": "200ms",
      "slow": "360ms"
    }
  },
  "density": {
    "default": {
      "row-h": "36px",
      "pad-x": "14px",
      "pad-y": "10px"
    },
    "compact": {
      "row-h": "30px",
      "pad-x": "10px",
      "pad-y": "7px"
    }
  },
  "z": {
    "base": 0,
    "sticky": 10,
    "overlay": 100,
    "dropdown": 200,
    "tooltip": 300,
    "toast": 400,
    "modal": 500,
    "palette": 600
  },
  "accent": {
    "h": 150,
    "rule": "One integer drives every accent shade via oklch(... var(--accent-h)). To rebrand from green, change this number."
  },
  "agentHues": {
    "description": "Six distinct hues, hashed by sum of agent name char codes mod 6. Never reused for state.",
    "light": [
      "oklch(62% 0.14 145)",
      "oklch(62% 0.12 275)",
      "oklch(64% 0.14 35)",
      "oklch(64% 0.10 210)",
      "oklch(60% 0.13 320)",
      "oklch(66% 0.13 85)"
    ],
    "dark": [
      "oklch(72% 0.14 145)",
      "oklch(72% 0.13 275)",
      "oklch(74% 0.14 35)",
      "oklch(74% 0.10 210)",
      "oklch(70% 0.13 320)",
      "oklch(76% 0.13 85)"
    ]
  },
  "userMark": {
    "from": "oklch(0.65 0.10 280)",
    "to": "oklch(0.55 0.12 200)",
    "rule": "Never reuse an agent color. Single gradient, all sizes."
  },
  "themes": {
    "light": {
      "colorScheme": "light",
      "neutral": {
        "bg": "oklch(99% 0.003 240)",
        "bg-elev": "oklch(98% 0.004 240)",
        "bg-sunk": "oklch(96% 0.005 240)",
        "bg-hover": "oklch(94% 0.006 240)",
        "line": "oklch(91% 0.005 240)",
        "line-soft": "oklch(94% 0.005 240)",
        "line-strong": "oklch(82% 0.008 240)",
        "text": "oklch(22% 0.008 240)",
        "text-2": "oklch(40% 0.008 240)",
        "text-3": "oklch(55% 0.008 240)",
        "text-4": "oklch(68% 0.008 240)"
      },
      "accent": {
        "base": "oklch(58% 0.16 var(--accent-h))",
        "strong": "oklch(48% 0.18 var(--accent-h))",
        "soft": "oklch(94% 0.06 var(--accent-h))",
        "ink": "oklch(28% 0.10 var(--accent-h))",
        "on": "#ffffff"
      },
      "semantic": {
        "danger": "oklch(56% 0.18 25)",
        "danger-soft": "oklch(94% 0.05 25)",
        "warn": "oklch(70% 0.13 75)",
        "warn-soft": "oklch(95% 0.06 75)",
        "info": "oklch(60% 0.10 240)",
        "info-soft": "oklch(95% 0.03 240)",
        "success": "oklch(58% 0.14 150)",
        "success-soft": "oklch(94% 0.05 150)"
      },
      "shadow": {
        "1": "0 1px 0 rgba(15,18,22,.04), 0 1px 2px rgba(15,18,22,.04)",
        "2": "0 1px 0 rgba(15,18,22,.04), 0 8px 24px -8px rgba(15,18,22,.10)",
        "pop": "0 12px 48px -12px rgba(15,18,22,.22)"
      },
      "focus": "0 0 0 2px var(--bg), 0 0 0 4px color-mix(in oklch, var(--accent) 70%, transparent)"
    },
    "dark": {
      "colorScheme": "dark",
      "neutral": {
        "bg": "oklch(15% 0.008 240)",
        "bg-elev": "oklch(18% 0.009 240)",
        "bg-sunk": "oklch(13% 0.008 240)",
        "bg-hover": "oklch(22% 0.010 240)",
        "line": "oklch(26% 0.008 240)",
        "line-soft": "oklch(22% 0.008 240)",
        "line-strong": "oklch(36% 0.010 240)",
        "text": "oklch(96% 0.005 240)",
        "text-2": "oklch(78% 0.006 240)",
        "text-3": "oklch(62% 0.007 240)",
        "text-4": "oklch(48% 0.007 240)"
      },
      "accent": {
        "base": "oklch(72% 0.16 var(--accent-h))",
        "strong": "oklch(80% 0.17 var(--accent-h))",
        "soft": "oklch(28% 0.08 var(--accent-h))",
        "ink": "oklch(86% 0.13 var(--accent-h))",
        "on": "oklch(15% 0.04 var(--accent-h))"
      },
      "semantic": {
        "danger": "oklch(72% 0.16 25)",
        "danger-soft": "oklch(28% 0.08 25)",
        "warn": "oklch(78% 0.13 75)",
        "warn-soft": "oklch(28% 0.07 75)",
        "info": "oklch(72% 0.10 240)",
        "info-soft": "oklch(26% 0.04 240)",
        "success": "oklch(72% 0.14 150)",
        "success-soft": "oklch(28% 0.07 150)"
      },
      "shadow": {
        "1": "0 1px 0 rgba(0,0,0,.4), 0 1px 2px rgba(0,0,0,.5)",
        "2": "0 1px 0 rgba(0,0,0,.4), 0 8px 28px -8px rgba(0,0,0,.6)",
        "pop": "0 12px 56px -12px rgba(0,0,0,.7)"
      },
      "focus": "0 0 0 2px var(--bg), 0 0 0 4px color-mix(in oklch, var(--accent) 60%, transparent)"
    }
  }
}
