{
  "$schema": "https://2200.local/schemas/tokens-v1.json",
  "version": "0.3.0",
  "description": "2200 design tokens. Canonical source of truth. tokens.css is generated from this file.",
  "naming": {
    "convention": "--<category>-<role>[-<variant>]",
    "categories": ["color", "type", "space", "radius", "border", "shadow", "duration", "ease", "z"]
  },
  "type": {
    "fontFamily": {
      "sans": "Inter, Helvetica Neue, system-ui, sans-serif",
      "mono": "JetBrains Mono, ui-monospace, SF Mono, Menlo, monospace"
    },
    "scale": {
      "display":   { "size": "32px", "track": "-0.025em", "weight": 500, "lh": 1.20 },
      "h1":        { "size": "22px", "track": "-0.015em", "weight": 500, "lh": 1.20 },
      "h2":        { "size": "17px", "track": "-0.01em",  "weight": 500, "lh": 1.35 },
      "h3":        { "size": "14px", "track": "-0.01em",  "weight": 500, "lh": 1.35 },
      "body":      { "size": "13px", "track": "-0.005em", "weight": 400, "lh": 1.45 },
      "body-sm":   { "size": "12px", "track": "-0.005em", "weight": 400, "lh": 1.45 },
      "label":     { "size": "11px", "track": "0.10em",   "weight": 500, "lh": 1.40, "case": "upper", "family": "mono" },
      "caption":   { "size": "10px", "track": "-0.005em", "weight": 400, "lh": 1.40 },
      "data":      { "size": "12px", "track": "-0.01em",  "weight": 400, "lh": 1.40, "family": "mono" },
      "data-lg":   { "size": "18px", "track": "-0.01em",  "weight": 500, "lh": 1.20, "family": "mono" },
      "data-xl":   { "size": "40px", "track": "-0.025em", "weight": 500, "lh": 1.10, "family": "mono" }
    }
  },
  "space": { "1": "4px", "2": "8px", "3": "12px", "4": "16px", "5": "20px", "6": "24px", "7": "32px", "8": "40px", "9": "56px", "10": "80px" },
  "radius": { "sm": "3px", "md": "6px", "lg": "8px", "pill": "999px" },
  "border": { "default": "1px", "emphasis": "2px" },
  "duration": { "fast": "120ms", "normal": "180ms", "slow": "280ms" },
  "ease": { "out": "cubic-bezier(0.2, 0.7, 0.2, 1)", "in-out": "cubic-bezier(0.45, 0, 0.55, 1)" },
  "z": { "base": 0, "sticky": 10, "overlay": 100, "dropdown": 200, "tooltip": 300, "toast": 400, "modal": 500, "palette": 600 },

  "agentPalette": {
    "description": "12-color deterministic palette. Agent id is hashed (sum of char codes × 31) modulo 12.",
    "colors": [
      "oklch(0.66 0.13 25)",  "oklch(0.70 0.13 55)",  "oklch(0.78 0.13 85)",
      "oklch(0.74 0.13 115)", "oklch(0.68 0.13 150)", "oklch(0.70 0.11 180)",
      "oklch(0.70 0.11 210)", "oklch(0.66 0.13 245)", "oklch(0.62 0.13 270)",
      "oklch(0.62 0.13 295)", "oklch(0.66 0.13 325)", "oklch(0.68 0.13 355)"
    ]
  },
  "userMark": {
    "from": "oklch(0.65 0.10 280)",
    "to":   "oklch(0.55 0.12 200)",
    "rule": "Never reuse an agent color. Single gradient, all sizes."
  },

  "themes": {
    "dark": {
      "color": {
        "bg-primary":    "oklch(0.16 0.005 250)",
        "bg-secondary":  "oklch(0.19 0.005 250)",
        "bg-elevated":   "oklch(0.22 0.006 250)",
        "bg-hover":      "oklch(0.26 0.007 250)",
        "bg-inset":      "oklch(0.13 0.005 250)",
        "bg-overlay":    "oklch(0.12 0.005 250 / 0.72)",

        "border-default":  "oklch(0.28 0.006 250)",
        "border-emphasis": "oklch(0.34 0.007 250)",
        "border-strong":   "oklch(0.45 0.008 250)",
        "divider":         "oklch(0.28 0.006 250)",

        "text-primary":   "oklch(0.97 0.003 250)",
        "text-secondary": "oklch(0.78 0.005 250)",
        "text-muted":     "oklch(0.60 0.006 250)",
        "text-disabled":  "oklch(0.45 0.006 250)",
        "text-inverse":   "oklch(0.16 0.005 250)",

        "status-running":      "oklch(0.74 0.14 150)",
        "status-running-bg":   "oklch(0.32 0.06 150 / 0.35)",
        "status-attention":    "oklch(0.80 0.13 75)",
        "status-attention-bg": "oklch(0.36 0.07 75 / 0.35)",
        "status-error":        "oklch(0.70 0.17 25)",
        "status-error-bg":     "oklch(0.34 0.09 25 / 0.40)",
        "status-info":         "oklch(0.74 0.10 245)",
        "status-info-bg":      "oklch(0.34 0.06 245 / 0.40)",

        "accent":     "oklch(0.85 0.005 250)",
        "accent-bg":  "oklch(0.30 0.005 250)",
        "accent-fg":  "oklch(0.16 0.005 250)",

        "focus-ring": "oklch(0.75 0.12 245)"
      },
      "shadow": {
        "elevation-1": "0 1px 0 oklch(1 0 0 / 0.04) inset, 0 1px 2px oklch(0 0 0 / 0.4)",
        "elevation-2": "0 12px 32px oklch(0 0 0 / 0.5), 0 1px 0 oklch(1 0 0 / 0.04) inset"
      }
    },
    "light": {
      "color": {
        "bg-primary":    "oklch(0.985 0.002 90)",
        "bg-secondary":  "oklch(1 0 0)",
        "bg-elevated":   "oklch(0.975 0.003 90)",
        "bg-hover":      "oklch(0.955 0.004 90)",
        "bg-inset":      "oklch(0.965 0.003 90)",
        "bg-overlay":    "oklch(0.20 0.005 250 / 0.18)",

        "border-default":  "oklch(0.92 0.004 90)",
        "border-emphasis": "oklch(0.86 0.005 90)",
        "border-strong":   "oklch(0.74 0.006 90)",
        "divider":         "oklch(0.92 0.004 90)",

        "text-primary":   "oklch(0.18 0.005 250)",
        "text-secondary": "oklch(0.36 0.006 250)",
        "text-muted":     "oklch(0.50 0.006 250)",
        "text-disabled":  "oklch(0.66 0.006 250)",
        "text-inverse":   "oklch(0.985 0.002 90)",

        "status-running":      "oklch(0.55 0.14 150)",
        "status-running-bg":   "oklch(0.93 0.05 150)",
        "status-attention":    "oklch(0.58 0.13 70)",
        "status-attention-bg": "oklch(0.94 0.06 75)",
        "status-error":        "oklch(0.55 0.18 25)",
        "status-error-bg":     "oklch(0.94 0.05 25)",
        "status-info":         "oklch(0.50 0.13 245)",
        "status-info-bg":      "oklch(0.94 0.04 245)",

        "accent":     "oklch(0.18 0.005 250)",
        "accent-bg":  "oklch(0.94 0.004 90)",
        "accent-fg":  "oklch(0.985 0.002 90)",

        "focus-ring": "oklch(0.55 0.15 245)"
      },
      "shadow": {
        "elevation-1": "0 1px 0 oklch(0 0 0 / 0.02) inset, 0 1px 2px oklch(0 0 0 / 0.06)",
        "elevation-2": "0 12px 32px oklch(0 0 0 / 0.10), 0 1px 0 oklch(0 0 0 / 0.02) inset"
      }
    }
  }
}
