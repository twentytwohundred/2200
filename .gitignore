# Node / TypeScript (added at Epic 2 build start)
node_modules/
dist/
build/
*.tsbuildinfo
.tscache/
coverage/

# Local env / secrets
.env
.env.*
*.pem
*.key
*.crt
secrets.*
# Source modules named secrets.* are part of the codebase; the rule
# above is meant for runtime-generated secret files (admin.secret,
# foo.secrets.json, etc.). Exempt explicit module paths.
!src/**/secrets.ts
!tests/**/secrets.ts

